# ─────────────────────────────────────────────────────────────
# Backend (Express) environment variables — VPS / Railway / Render
# Copy to .env (local) or set as platform env vars (production).
# ─────────────────────────────────────────────────────────────

PORT=4000

# Must be "production" on the host; local dev can stay "development".
NODE_ENV=production

# MongoDB Atlas connection string (REQUIRED in production).
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/infinityai
MONGO_URI=
MONGO_DB=infinityai

# Frontend origin(s) allowed by CORS, comma-separated.
# REQUIRED in production. Example: https://infinityai.vercel.app
CLIENT_ORIGIN=

# Auth
# REQUIRED in production. Use a strong random secret.
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d
AUTH_SALT_ROUNDS=12

# Optional admin seed (creates an admin user on first start)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Email Service ──────────────────────────────────────────────
EMAIL_FROM=InfinityAI <noreply@infinityai.app>

# Resend
RESEND_API_KEY=

# ── Ollama (kept; long-running local/remote LLM server) ──────
# In production use the hosted/reachable Ollama URL, e.g.:
# http://ollama.internal:11434 or https://ollama.yourdomain.com
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── ComfyUI (kept; long-running image generation server) ────
# In production use the hosted/reachable ComfyUI URL, e.g.:
# http://comfyui.internal:8188 or https://comfyui.yourdomain.com
COMFYUI_URL=http://127.0.0.1:8188

# ─────────────────────────────────────────────────────────────
# Universal AI Providers (Phase 2)
# Only Ollama (above) works out of the box. The cloud providers below are
# wired as configuration placeholders: add a key to mark them "configured".
# Live calls are activated in a later phase. Base URLs are optional overrides.
# ─────────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Anthropic Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# DeepSeek
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Mistral
MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# OpenRouter
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─────────────────────────────────────────────────────────────
# Frontend (Vite) build-time variable — set in Vercel.
# Points the browser at the deployed backend API.
# Example: https://infinityai-backend.up.railway.app/api
# ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=
